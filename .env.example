APP_NAME=Async Task Service
APP_ENV=local

API_PORT=8000

POSTGRES_DB=tasks
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/tasks

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

TASK_QUEUE_NAME=tasks
WORKER_CONCURRENCY=4
HEALTHCHECK_TIMEOUT_SECONDS=3
